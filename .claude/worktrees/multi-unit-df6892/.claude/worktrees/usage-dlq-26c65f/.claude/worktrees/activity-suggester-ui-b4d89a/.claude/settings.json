{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(supabase start)",
      "Bash(supabase stop)",
      "Bash(supabase status)",
      "Bash(supabase db reset)",
      "Bash(supabase db diff *)",
      "Bash(supabase migration new *)",
      "Bash(supabase migration list)",
      "Bash(supabase gen types typescript --local*)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)"
    ],
    "deny": [
      "Bash(supabase link*)",
      "Bash(supabase db push*)",
      "Bash(supabase db pull*)",
      "Bash(supabase db remote*)",
      "Bash(supabase secrets*)",
      "Bash(supabase functions deploy*)",
      "Bash(supabase projects*)",
      "Bash(supabase --project-ref*)",
      "Bash(* --linked*)",
      "Bash(psql *prod*)",
      "Bash(psql *production*)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)"
    ]
  }
}

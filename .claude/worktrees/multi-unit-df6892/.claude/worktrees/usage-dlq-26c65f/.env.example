# ---------------------------------------------------------------------------
# Rally environment variables
#
# Copy this file to `.env.local` and fill in real values. Never commit `.env`.
# Vars prefixed with NEXT_PUBLIC_ are exposed to the browser; everything else
# is server-only and must never be referenced from a "use client" component.
# ---------------------------------------------------------------------------

# --- Supabase (public, RLS-bounded) ----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only, bypasses RLS) ----------------------------------
# Used only from workers/ and admin scripts. Never import from app/.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic --------------------------------------------------------------
# Server-only. All Claude calls originate from agents/* via lib/anthropic/.
ANTHROPIC_API_KEY=

# Optional: override the default model alias (see lib/anthropic/models.ts).
# Leave unset to use the per-agent defaults.
# ANTHROPIC_MODEL_SONNET=claude-sonnet-4-5
# ANTHROPIC_MODEL_OPUS=claude-opus-4-5
# ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5

# --- Rally app secrets ------------------------------------------------------
# 32-byte key (base64) used by lib/crypto.ts for app-level at-rest encryption
# of fields the database shouldn't see in plaintext (e.g. parent contact notes).
RALLY_ENCRYPTION_KEY=

# Salt for the SHA-256 hash that anonymises user/unit identifiers in
# usage_events. Rotate carefully — rotation breaks historical correlation.
RALLY_USAGE_HASH_SALT=

# --- Feature flags ----------------------------------------------------------
# Enables claude-opus-4-5 in lesson_planner's deep-reasoning path.
RALLY_FLAG_LESSON_PLANNER_DEEP=false

# --- Local development ------------------------------------------------------
# Defaults match `supabase start` output. Override only if you know why.
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
